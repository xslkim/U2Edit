{
  "name": "lwb-ui-editor",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "typecheck:e2e": "tsc --noEmit --project tsconfig.e2e.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "tauri": "tauri",
    "test:e2e": "wdio run wdio.conf.ts",
    "test:e2e:build": "pnpm tauri build --debug && wdio run wdio.conf.ts",
    "test:e2e:spec": "wdio run wdio.conf.ts --spec"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-fs": "^2.5.0",
    "@tauri-apps/plugin-opener": "^2",
    "konva": "^10.2.5",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/test-utils": "^2.4.6",
    "@wdio/cli": "^9.27.0",
    "@wdio/globals": "^9.27.0",
    "@wdio/junit-reporter": "^9.27.0",
    "@wdio/local-runner": "^9.27.0",
    "@wdio/mocha-framework": "^9.27.0",
    "@wdio/spec-reporter": "^9.27.0",
    "@wdio/tauri-service": "1.0.0-next.0",
    "@wdio/types": "^9.27.0",
    "happy-dom": "^15.11.7",
    "tsx": "^4.21.0",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vitest": "^3.0.5",
    "vue-tsc": "^2.1.10",
    "webdriverio": "^9.27.0"
  }
}
